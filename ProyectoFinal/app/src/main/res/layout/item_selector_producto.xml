<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="horizontal"
  android:gravity="center_vertical"
  android:padding="8dp">

  <TextView
    android:id="@+id/tvSelectorNombre"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:text="Producto — $0.00"
    android:textSize="14sp" />

  <ImageButton
    android:id="@+id/btnSelectorMenos"
    android:layout_width="36dp"
    android:layout_height="36dp"
    android:src="@drawable/baseline_minus"
    android:contentDescription="Decrementar"
    android:background="?attr/selectableItemBackgroundBorderless" />

  <TextView
    android:id="@+id/tvSelectorCantidad"
    android:layout_width="40dp"
    android:layout_height="wrap_content"
    android:text="0"
    android:gravity="center"
    android:textSize="14sp" />

  <ImageButton
    android:id="@+id/btnSelectorMas"
    android:layout_width="36dp"
    android:layout_height="36dp"
    android:src="@drawable/baseline_add"
    android:contentDescription="Aumentar"
    android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>
