<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MisProductosActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/purple_700"
            app:titleTextColor="@android:color/white" />

        <!-- SearchBar -->
        <EditText
            android:id="@+id/etBuscarProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar producto por nombre..."
            android:inputType="text"
            android:padding="12dp"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:background="@android:color/white"
            android:elevation="2dp" />

        <!-- Secciones por tipo -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- ALIMENTOS -->
                <TextView
                    android:id="@+id/tvTituloAlimento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alimentos"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp" />

                <HorizontalScrollView
                    android:id="@+id/hsvAlimentos"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/llAlimentos"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <!-- BEBIDAS -->
                <TextView
                    android:id="@+id/tvTituloBebida"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bebidas"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp" />

                <HorizontalScrollView
                    android:id="@+id/hsvBebidas"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/llBebidas"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <!-- POSTRES -->
                <TextView
                    android:id="@+id/tvTituloPostre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Postres"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp" />

                <HorizontalScrollView
                    android:id="@+id/hsvPostres"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp">
                    <LinearLayout
                        android:id="@+id/llPostres"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <!-- EXTRAS -->
                <TextView
                    android:id="@+id/tvTituloExtra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Extras"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp" />

                <HorizontalScrollView
                  android:id="@+id/hsvExtras"
                  android:layout_width="match_parent"
                  android:layout_height="120dp"
                  android:layout_marginBottom="8dp">
                  <LinearLayout
                    android:id="@+id/llExtras"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
      android:id="@+id/nav_view"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:layout_gravity="start"
      app:menu="@menu/nav_drawer_menu"
      app:headerLayout="@layout/nav_drawer_header" />
</androidx.drawerlayout.widget.DrawerLayout>
